spring:
  datasource:
    url: jdbc:mysql://localhost:3306/lostark?useSSL=false&characterEncoding=UTF-8&serverTimezone=Asia/Seoul
    username: YOUR_DB_USERNAME
    password: YOUR_DB_PASSWORD
    driver-class-name: com.mysql.cj.jdbc.Driver
  jpa:
    hibernate:
      ddl-auto: update
    show-sql: true
    properties:
      hibernate:
        format_sql: true
        dialect: org.hibernate.dialect.MySQL8Dialect

lostark:
  api:
    key: YOUR_LOSTARK_API_KEY
    base-url: https://developer-lostark.game.onstove.com

server:
  port: 8080

logging:
  level:
    "[org.springframework.web.servlet.resource]": ERROR
